<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_institute_pnl_report_wizard_form" model="ir.ui.view">
        <field name="name">institute.pnl.report.wizard.form</field>
        <field name="model">institute.pnl.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Profit and Loss Report">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="branch_id" options="{'no_create': True}" groups="institute_accounting.group_institute_accounting_manager"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_report" string="Generate Report" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_institute_pnl_report_wizard" model="ir.actions.act_window">
        <field name="name">Profit &amp; Loss Report</field>
        <field name="res_model">institute.pnl.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
