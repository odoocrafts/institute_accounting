<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_institute_accounting_refund_wizard_form" model="ir.ui.view">
        <field name="name">institute.accounting.refund.wizard.form</field>
        <field name="model">institute.accounting.refund.wizard</field>
        <field name="arch" type="xml">
            <form string="Refund Fee">
                <sheet>
                    <group>
                        <group>
                            <field name="transaction_id"/>
                            <field name="amount"/>
                        </group>
                        <group>
                            <field name="account_id" options="{'no_create': True}"/>
                            <field name="payment_method"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason" placeholder="e.g. Student dropped course..."/>
                    </group>
                </sheet>
                <footer>
                    <button string="Confirm Refund" name="action_confirm_refund" type="object" class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
