<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action -->
    <record id="action_institute_accounting_transaction" model="ir.actions.act_window">
        <field name="name">Transactions</field>
        <field name="res_model">institute.accounting.transaction</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_by_branch': 1}</field>
    </record>

    <!-- Tree View -->
    <record id="view_institute_accounting_transaction_tree" model="ir.ui.view">
        <field name="name">institute.accounting.transaction.tree</field>
        <field name="model">institute.accounting.transaction</field>
        <field name="arch" type="xml">
            <tree decoration-success="transaction_type=='income'" decoration-danger="transaction_type=='expense'">
                <field name="name"/>
                <field name="date"/>
                <field name="branch_id"/>
                <field name="transaction_type"/>
                <field name="paid_to" optional="show"/>
                <field name="payment_method"/>
                <field name="amount" sum="Total Amount"/>
                <field name="state" widget="badge" decoration-info="state=='draft'" decoration-warning="state=='submitted'" decoration-success="state=='paid' or state=='approved'"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_institute_accounting_transaction_form" model="ir.ui.view">
        <field name="name">institute.accounting.transaction.form</field>
        <field name="model">institute.accounting.transaction</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_print_voucher" type="object" string="Print Voucher" invisible="transaction_type == 'income'" class="oe_highlight"/>
                    <button name="action_print_receipt" type="object" string="Print Receipt" invisible="transaction_type != 'income' or state != 'paid'" class="oe_highlight"/>
                    <button name="action_paid" type="object" string="Mark as Paid / Received" invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_refund" type="object" string="Refund" invisible="transaction_type != 'income' or state != 'paid'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,paid,refunded"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="is_manager" invisible="1"/>
                            <field name="transaction_type" readonly="state != 'draft'"/>
                            <field name="branch_id" readonly="not is_manager or state != 'draft'" force_save="1"/>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="amount" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="fee_type_id" invisible="transaction_type != 'income'" readonly="state != 'draft'" required="transaction_type == 'income'"/>
                            <field name="expense_type_id" invisible="transaction_type != 'expense'" readonly="state != 'draft'" required="transaction_type == 'expense'"/>
                            <field name="paid_to" invisible="transaction_type != 'expense'" readonly="state != 'draft'"/>
                            
                            <!-- Fee Collection Fields -->
                            <field name="course_id" invisible="transaction_type != 'income'" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="batch_id" invisible="transaction_type != 'income'" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="course_variant_id" invisible="transaction_type != 'income'" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="student_id" invisible="transaction_type != 'income'" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="accounting_fee_line_id" invisible="transaction_type != 'income'" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="student_due" invisible="transaction_type != 'income' or not student_id" readonly="1"/>

                            <field name="account_id" options="{'no_create': True}" readonly="state != 'draft'" required="1"/>
                            <field name="payment_method" readonly="1" force_save="1"/>
                            <field name="transaction_ref" invisible="payment_method == 'cash'" readonly="state != 'draft'"/>
                            <field name="payment_status" invisible="transaction_type != 'expense'" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Add a description..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_institute_accounting_transaction_search" model="ir.ui.view">
        <field name="name">institute.accounting.transaction.search</field>
        <field name="model">institute.accounting.transaction</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="branch_id"/>
                <field name="transaction_ref"/>
                <filter string="Income" name="income" domain="[('transaction_type', '=', 'income')]"/>
                <filter string="Expense" name="expense" domain="[('transaction_type', '=', 'expense')]"/>
                <group expand="0" string="Group By">
                    <filter string="Branch" name="group_by_branch" context="{'group_by': 'branch_id'}"/>
                    <filter string="Type" name="group_by_type" context="{'group_by': 'transaction_type'}"/>
                    <filter string="Date" name="group_by_date" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <menuitem id="menu_institute_action_transactions" name="All Transactions" parent="menu_institute_accounting_transactions" action="action_institute_accounting_transaction" sequence="10"/>
</odoo>
