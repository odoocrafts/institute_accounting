<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action -->
    <record id="action_institute_accounting_student" model="ir.actions.act_window">
        <field name="name">Accounting Students</field>
        <field name="res_model">institute.accounting.student</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_by_batch_period': 1, 'search_default_group_by_batch_id': 1}</field>
    </record>

    <!-- Search View -->
    <record id="view_institute_accounting_student_search" model="ir.ui.view">
        <field name="name">institute.accounting.student.search</field>
        <field name="model">institute.accounting.student</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="branch_id"/>
                <field name="course_id"/>
                <field name="batch_id"/>
                <field name="batch_period"/>
                <group expand="0" string="Group By">
                    <filter string="Batch Period" name="group_by_batch_period" context="{'group_by':'batch_period'}"/>
                    <filter string="Batch Name" name="group_by_batch_id" context="{'group_by':'batch_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_institute_accounting_student_tree" model="ir.ui.view">
        <field name="name">institute.accounting.student.tree</field>
        <field name="model">institute.accounting.student</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="branch_id"/>
                <field name="course_id"/>
                <field name="batch_period"/>
                <field name="student_number"/>
                <field name="parent_number"/>
                <field name="total_fee" sum="Total Configured Fee"/>
                <field name="total_paid" sum="Total Paid"/>
                <field name="total_due" sum="Total Due"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_institute_accounting_student_form" model="ir.ui.view">
        <field name="name">institute.accounting.student.form</field>
        <field name="model">institute.accounting.student</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Student Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="branch_id"/>
                            <field name="course_id" options="{'no_create': True}"/>
                            <field name="batch_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="student_number"/>
                            <field name="parent_number"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Semester Dues">
                            <field name="fee_line_ids">
                                <tree editable="bottom">
                                    <field name="semester_id" options="{'no_create': True}"/>
                                    <field name="total_fee"/>
                                    <field name="paid_amount"/>
                                    <field name="due_amount"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_fee"/>
                                <field name="total_paid"/>
                                <field name="total_due" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <menuitem id="menu_institute_accounting_students" name="Students Dues" parent="menu_institute_accounting_transactions" action="action_institute_accounting_student" sequence="5"/>
</odoo>
