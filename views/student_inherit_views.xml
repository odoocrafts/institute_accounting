<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_student_student_form_inherit_accounting" model="ir.ui.view">
        <field name="name">student.student.form.inherit.accounting</field>
        <field name="model">student.student</field>
        <field name="inherit_id" ref="student_management.view_student_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='course_fee']" position="before">
                <field name="opening_balance"/>
                <field name="current_semester_id"/>
                <field name="computed_due"/>
            </xpath>
        </field>
    </record>

    <!-- Menu action to see Students in Accounting -->
    <record id="action_student_student_accounting" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">student.student</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_accounting_students"
              name="Students"
              parent="menu_institute_accounting_transactions"
              action="action_student_student_accounting"
              sequence="20"/>
</odoo>
