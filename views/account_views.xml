<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action -->
    <record id="action_institute_account" model="ir.actions.act_window">
        <field name="name">Institute Accounts</field>
        <field name="res_model">institute.account</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Tree View -->
    <record id="view_institute_account_tree" model="ir.ui.view">
        <field name="name">institute.account.tree</field>
        <field name="model">institute.account</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="branch_id"/>
                <field name="account_type"/>
                <field name="opening_balance"/>
                <field name="current_balance"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_institute_account_form" model="ir.ui.view">
        <field name="name">institute.account.form</field>
        <field name="model">institute.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Main Petty Cash"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="account_type"/>
                            <field name="branch_id"/>
                        </group>
                        <group>
                            <field name="opening_balance"/>
                            <field name="current_balance"/>
                            <field name="account_number" invisible="account_type == 'cash'"/>
                            <field name="bank_name" invisible="account_type == 'cash'"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem id="menu_institute_action_accounts" name="Bank/Cash Accounts" parent="menu_institute_accounting_config" action="action_institute_account" sequence="40"/>
</odoo>
