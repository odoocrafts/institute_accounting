<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View for inheriting student.fee.payment -->
    <record id="view_student_fee_payment_form_inherit" model="ir.ui.view">
        <field name="name">student.fee.payment.form.inherit.accounting</field>
        <field name="model">student.fee.payment</field>
        <!-- student_management does not have a defined action/view for student.fee.payment natively outside of student form. Let's make one if needed. Actually let's just make our own form view since nothing exists independently. Wait, we can define a normal form and tree view and give a high priority. -->
        <field name="arch" type="xml">
            <form string="Fee Payment Collection">
                <header>
                    <button name="action_print_receipt" string="Receipt" type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group name="selection">
                            <field name="course_id" options="{'no_create': True}"/>
                            <field name="batch_id" options="{'no_create': True}"/>
                            <field name="student_id" required="1" options="{'no_create': True}"/>
                            <field name="semester_id" options="{'no_create': True}"/>
                        </group>
                        <group name="payment">
                            <field name="payment_date"/>
                            <field name="amount"/>
                            <field name="payment_method"/>
                            <field name="reference" invisible="payment_method == 'cash'"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Additional Notes"/>
                        <field name="branch_id" readonly="1" force_save="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_student_fee_payment_tree" model="ir.ui.view">
        <field name="name">student.fee.payment.tree</field>
        <field name="model">student.fee.payment</field>
        <field name="arch" type="xml">
            <tree string="Fee Payments" default_order="payment_date desc">
                <field name="name"/>
                <field name="payment_date"/>
                <field name="student_id"/>
                <field name="course_id"/>
                <field name="batch_id"/>
                <field name="semester_id"/>
                <field name="amount" sum="Total"/>
                <field name="payment_method"/>
            </tree>
        </field>
    </record>
    
    <!-- Pivot View for Fee Due Report -->
    <!-- The user asks: "We need fee due report based on per batch, per course" 
         A pivot view on student.student works perfectly to see Due amounts! -->
    <record id="view_student_due_pivot" model="ir.ui.view">
        <field name="name">student.student.due.pivot</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <pivot string="Fee Due Report" disable_linking="True">
                <field name="course_id" type="row"/>
                <field name="batch_id" type="row"/>
                <field name="computed_due" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Due Report Action -->
    <record id="action_student_due_report" model="ir.actions.act_window">
        <field name="name">Fee Due Report</field>
        <field name="res_model">student.student</field>
        <field name="view_mode">pivot,tree,form</field>
        <field name="view_id" ref="view_student_due_pivot"/>
    </record>

    <!-- Collection Action -->
    <record id="action_student_fee_collection" model="ir.actions.act_window">
        <field name="name">Fee Collections</field>
        <field name="res_model">student.fee.payment</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_accounting_fee_collection"
              name="Fee Collections"
              parent="menu_institute_accounting_transactions"
              action="action_student_fee_collection"
              sequence="25"/>
              
    <menuitem id="menu_accounting_fee_due_report"
              name="Fee Due Report"
              parent="menu_institute_accounting_reports"
              action="action_student_due_report"
              sequence="20"/>

</odoo>
