<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Top Menu -->
    <menuitem id="menu_institute_accounting_root" name="Books" sequence="50" action="action_institute_dashboard" web_icon="institute_accounting,static/description/icon.png"/>
    
    <!-- Submenus -->
    <menuitem id="menu_institute_accounting_dashboard" name="Dashboard" parent="menu_institute_accounting_root" action="action_institute_dashboard" sequence="5"/>
    <menuitem id="menu_institute_accounting_transactions" name="Transactions" parent="menu_institute_accounting_root" sequence="10"/>
    <menuitem id="menu_institute_accounting_reports" name="Reporting" parent="menu_institute_accounting_root" sequence="20"/>
    <menuitem id="menu_institute_accounting_config" name="Configuration" parent="menu_institute_accounting_root" sequence="30" groups="institute_accounting.group_institute_accounting_manager"/>

    <!-- Branch Menu in Configuration -->
    <record id="action_institute_accounting_branch" model="ir.actions.act_window">
        <field name="name">Branches</field>
        <field name="res_model">student.branch</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_institute_accounting_branch" name="Branches" parent="menu_institute_accounting_config" action="action_institute_accounting_branch" sequence="5"/>

    <!-- Course Menu -->
    <record id="action_institute_accounting_course" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">product.product</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('type', '=', 'service')]</field>
        <field name="context">{'default_type': 'service'}</field>
    </record>
    <menuitem id="menu_institute_accounting_course" name="Courses" parent="menu_institute_accounting_config" action="action_institute_accounting_course" sequence="6"/>

    <!-- Batch Menu -->
    <record id="action_institute_accounting_batch" model="ir.actions.act_window">
        <field name="name">Batches</field>
        <field name="res_model">student.batch</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_institute_accounting_batch" name="Batches" parent="menu_institute_accounting_config" action="action_institute_accounting_batch" sequence="7"/>
</odoo>
