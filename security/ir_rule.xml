<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Branch Accountant: Own branch transactions only -->
        <record id="rule_institute_accounting_transaction_branch" model="ir.rule">
            <field name="name">Branch Accountant Transactions</field>
            <field name="model_id" ref="model_institute_accounting_transaction"/>
            <field name="domain_force">['|', ('branch_id.accountant_id', '=', user.id), ('branch_id', 'in', user.branch_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('institute_accounting.group_institute_accounting_branch'))]"/>
        </record>

        <!-- Finance Manager: All transactions -->
        <record id="rule_institute_accounting_transaction_manager" model="ir.rule">
            <field name="name">Finance Manager Transactions All</field>
            <field name="model_id" ref="model_institute_accounting_transaction"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('institute_accounting.group_institute_accounting_manager'))]"/>
        </record>

        <!-- Branch Accountant Report -->
        <record id="rule_institute_accounting_report_branch" model="ir.rule">
            <field name="name">Branch Accountant Report</field>
            <field name="model_id" ref="model_institute_accounting_report"/>
            <field name="domain_force">['|', ('branch_id.accountant_id', '=', user.id), ('branch_id', 'in', user.branch_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('institute_accounting.group_institute_accounting_branch'))]"/>
        </record>

        <!-- Finance Manager Report -->
        <record id="rule_institute_accounting_report_manager" model="ir.rule">
            <field name="name">Finance Manager Report All</field>
            <field name="model_id" ref="model_institute_accounting_report"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('institute_accounting.group_institute_accounting_manager'))]"/>
        </record>
    </data>
</odoo>
