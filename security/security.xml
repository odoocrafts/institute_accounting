<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_institute_accounting" model="ir.module.category">
            <field name="name">Institute Accounting</field>
            <field name="description">Institute Accounting Access Rights</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_institute_accounting_branch" model="res.groups">
            <field name="name">Branch Accountant</field>
            <field name="category_id" ref="module_category_institute_accounting"/>
        </record>

        <record id="group_institute_accounting_manager" model="res.groups">
            <field name="name">Finance Manager</field>
            <field name="category_id" ref="module_category_institute_accounting"/>
            <field name="implied_ids" eval="[(4, ref('group_institute_accounting_branch'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
