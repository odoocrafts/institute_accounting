<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_pnl" model="ir.actions.report">
        <field name="name">Profit &amp; Loss Report</field>
        <field name="model">institute.pnl.report.wizard</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">institute_accounting.report_pnl_template</field>
        <field name="report_file">institute_accounting.report_pnl_template</field>
        <field name="binding_type">report</field>
    </record>

    <template id="report_pnl_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <div class="oe_structure"/>
                    
                    <!-- Header -->
                    <div class="row mt-4 mb-4">
                        <div class="col-12 text-center">
                            <h2 class="fw-bold">Profit &amp; Loss Account</h2>
                            <h4 class="text-muted"><t t-esc="branch_name"/></h4>
                            <div class="mt-2 text-muted">
                                <t t-if="date_from and date_to">
                                    <span>For the period from <t t-esc="date_from" t-options='{"widget": "date"}'/> to <t t-esc="date_to" t-options='{"widget": "date"}'/></span>
                                </t>
                                <t t-elif="date_from">
                                    <span>For the period from <t t-esc="date_from" t-options='{"widget": "date"}'/></span>
                                </t>
                                <t t-elif="date_to">
                                    <span>For the period up to <t t-esc="date_to" t-options='{"widget": "date"}'/></span>
                                </t>
                            </div>
                        </div>
                    </div>

                    <!-- T-Format P&L Table -->
                    <table class="table table-bordered table-sm o_main_table mt-4" style="font-size: 1.1em; border: 2px solid black;">
                        <thead>
                            <tr class="text-center" style="border-bottom: 2px solid black;">
                                <th class="w-50 border-end" style="border-color: black !important;">
                                    <strong>Particulars (Expenses/Dr)</strong>
                                </th>
                                <th class="w-50">
                                    <strong>Particulars (Income/Cr)</strong>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <!-- Left Column: Expenses -->
                                <td class="p-0 border-end" style="border-color: black !important; vertical-align: top;">
                                    <table class="table table-sm table-borderless mb-0 w-100">
                                        <t t-foreach="expense_list" t-as="expense">
                                            <tr>
                                                <td class="ps-2">To <t t-esc="expense['category']"/></td>
                                                <td class="text-end pe-2"><t t-esc="expense['amount']" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/></td>
                                            </tr>
                                        </t>
                                        <t t-if="net_profit &gt;= 0">
                                            <tr class="fw-bold text-success">
                                                <td class="ps-2">To Net Profit</td>
                                                <td class="text-end pe-2"><t t-esc="net_profit" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/></td>
                                            </tr>
                                        </t>
                                    </table>
                                </td>
                                <!-- Right Column: Income -->
                                <td class="p-0" style="vertical-align: top;">
                                    <table class="table table-sm table-borderless mb-0 w-100">
                                        <t t-foreach="income_list" t-as="income">
                                            <tr>
                                                <td class="ps-2">By <t t-esc="income['category']"/></td>
                                                <td class="text-end pe-2"><t t-esc="income['amount']" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/></td>
                                            </tr>
                                        </t>
                                        <t t-if="net_profit &lt; 0">
                                            <tr class="fw-bold text-danger">
                                                <td class="ps-2">By Net Loss</td>
                                                <td class="text-end pe-2"><t t-esc="abs(net_profit)" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/></td>
                                            </tr>
                                        </t>
                                    </table>
                                </td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr class="fw-bold fs-6" style="border-top: 2px solid black;">
                                <td class="border-end" style="border-color: black !important;">
                                    <div class="d-flex justify-content-between px-2">
                                        <span>Total</span>
                                        <span><t t-esc="max(total_income, total_expense)" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/></span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex justify-content-between px-2">
                                        <span>Total</span>
                                        <span><t t-esc="max(total_income, total_expense)" t-options='{"widget": "monetary", "display_currency": company.currency_id}'/></span>
                                    </div>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                    <div class="oe_structure"/>
                </div>
            </t>
        </t>
    </template>
</odoo>
