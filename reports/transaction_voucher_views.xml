<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Paper Format -->
    <record id="paperformat_voucher_landscape" model="report.paperformat">
        <field name="name">Voucher Landscape A4</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">40</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">35</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_transaction_voucher" model="ir.actions.report">
        <field name="name">Transaction Voucher</field>
        <field name="model">institute.accounting.transaction</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">institute_accounting.report_transaction_voucher_template</field>
        <field name="report_file">institute_accounting.report_transaction_voucher_template</field>
        <field name="binding_model_id" ref="institute_accounting.model_institute_accounting_transaction"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="institute_accounting.paperformat_voucher_landscape"/>
    </record>

    <template id="report_transaction_voucher_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <!-- Custom Header -->
                    <div class="header">
                        <div class="row pt-4 text-dark" style="border-bottom: 1px solid #dee2e6; padding-bottom: 10px; margin-bottom: 20px;">
                            <div class="col-4 text-left">
                                <img t-if="env.company.logo" t-att-src="image_data_uri(env.company.logo)" style="max-height: 80px;" alt="Logo"/>
                            </div>
                            <div class="col-8 text-right" style="font-size: 14px;">
                                <strong style="font-size: 20px;"><span t-field="env.company.name"/></strong><br/>
                                <strong style="font-size: 16px;"><span t-field="doc.branch_id.name"/></strong><br/>
                                <span t-esc="doc.branch_id.billing_address or 'No Billing Address Setup'"/><br/>
                                <span>GSTIN: <span t-esc="doc.branch_id.gstin or 'N/A'"/></span>
                            </div>
                        </div>
                    </div>

                    <div class="page text-dark">
                        <div class="row mt16 mb16">
                            <div class="col-8">
                                <h3 class="mb-0">Payment Voucher: <span t-field="doc.name"/></h3>
                            </div>
                            <div class="col-4 text-right">
                                <strong>Status:</strong> <span class="text-uppercase" t-field="doc.state"/>
                            </div>
                        </div>

                        <table class="table table-bordered mt16 mb32" style="border: 1px solid #495057; font-size: 15px;">
                            <tr>
                                <th width="20%" class="bg-light p-3">Branch</th>
                                <td width="30%" class="p-3">
                                    <strong t-field="doc.branch_id.name"/>
                                </td>
                                <th width="20%" class="bg-light p-3">Date</th>
                                <td class="p-3"><span t-field="doc.date"/></td>
                            </tr>
                            <tr>
                                <th class="bg-light p-3">Type</th>
                                <td class="p-3"><span class="text-capitalize" t-field="doc.transaction_type"/></td>
                                <th class="bg-light p-3">Category</th>
                                <td class="p-3">
                                    <span t-if="doc.transaction_type == 'income'" t-field="doc.fee_type_id.name"/>
                                    <span t-if="doc.transaction_type == 'expense'" t-field="doc.expense_type_id.name"/>
                                </td>
                            </tr>
                            <tr t-if="doc.transaction_type == 'expense'">
                                <th class="bg-light p-3">Paid To</th>
                                <td class="p-3"><span t-field="doc.paid_to"/></td>
                                <th class="bg-light p-3">Reference</th>
                                <td class="p-3"><span t-esc="doc.transaction_ref or 'N/A'"/></td>
                            </tr>
                            <tr t-if="doc.transaction_type == 'income'">
                                <th class="bg-light p-3">Reference</th>
                                <td colspan="3" class="p-3"><span t-esc="doc.transaction_ref or 'N/A'"/></td>
                            </tr>
                            <tr>
                                <th class="bg-light p-3">Payment Method</th>
                                <td class="p-3"><span class="text-capitalize" t-field="doc.payment_method"/></td>
                                <th class="bg-light text-right p-3">Amount</th>
                                <td class="text-right p-3"><strong style="font-size: 16px;"><span t-field="doc.amount" t-options='{"widget": "monetary", "display_currency": env.company.currency_id}'/></strong></td>
                            </tr>
                        </table>

                        <div t-if="doc.description" class="mt16">
                            <strong>Description:</strong>
                            <p t-field="doc.description"/>
                        </div>
                        <div class="row mt16 align-items-end" style="page-break-inside: avoid;">
                            <div class="col-4 text-center">
                                <div style="margin-bottom: 5px;">
                                    <br/><br/><br/>
                                    <strong style="font-size: 16px;" t-esc="doc.branch_id.accountant_id.name or doc.create_uid.name or 'Accountant'"></strong>
                                </div>
                                <div style="border-top: 1px solid #adb5bd; padding-top: 5px; width: 80%; margin: 0 auto; font-size: 15px;">
                                    <strong>Prepared By</strong>
                                </div>
                            </div>
                            <!-- Round Seal -->
                            <div class="col-4 text-center">
                                <div t-if="doc.branch_id.round_seal" style="margin-bottom: 5px;">
                                    <img t-att-src="image_data_uri(doc.branch_id.round_seal)" style="max-height: 180px; max-width: 300px; mix-blend-mode: multiply;"/>
                                </div>
                                <div t-else="" style="margin-bottom: 5px;">
                                    <br/><br/>
                                </div>
                            </div>
                            <div class="col-4 text-center">
                                <div t-if="doc.branch_id.accountant_signature" style="margin-bottom: 5px;">
                                    <img t-att-src="image_data_uri(doc.branch_id.accountant_signature)" style="max-height: 180px; max-width: 400px; mix-blend-mode: multiply;"/>
                                </div>
                                <div t-else="" style="margin-bottom: 5px;">
                                    <br/><br/>
                                </div>
                                <div style="border-top: 1px solid #adb5bd; padding-top: 5px; width: 80%; margin: 0 auto; font-size: 15px;">
                                    <strong>Authorized Signatory</strong><br/>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-4" style="height: 20px;"></div>
                    </div>

                    <!-- Custom Footer -->
                    <div class="footer o_standard_footer">
                        <div class="text-center" style="border-top: 1px solid #adb5bd; padding-top: 10px; font-size: 12px; color: #495057;">
                            <div class="row mb-1">
                                <div class="col-12">
                                    <span t-if="doc.branch_id.phone">
                                        <span t-esc="doc.branch_id.phone"/> 
                                    </span>
                                    <span t-if="doc.branch_id.phone and doc.branch_id.email">
                                        | 
                                    </span>
                                    <span t-if="doc.branch_id.email">
                                        <span t-esc="doc.branch_id.email"/>
                                    </span>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12">
                                    <span class="text-muted" style="font-size: 10px;">
                                        <em>This is a Computer Generated Payment Voucher</em><br/>
                                        Page <span class="page"/> / <span class="topage"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
